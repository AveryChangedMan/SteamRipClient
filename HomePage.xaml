<Page
    x:Class="SteamRipApp.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SteamRipApp"
    xmlns:core="using:SteamRipApp.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Page.Resources>
        <core:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <core:InvertedBooleanToVisibilityConverter x:Key="InvertedBoolToVis" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" Margin="0,0,0,12" Background="Transparent" IsOpen="False" IsSticky="True" OverflowButtonVisibility="Collapsed">
            <AppBarButton Icon="Home" Label="Home" Click="NavHome_Click"/>

            <AppBarButton Icon="List" Label="Categories">
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Action" Click="NavCategory_Click" Tag="action"/>
                        <MenuFlyoutItem Text="Adventure" Click="NavCategory_Click" Tag="adventure"/>
                        <MenuFlyoutItem Text="Anime" Click="NavCategory_Click" Tag="anime"/>
                        <MenuFlyoutItem Text="Horror" Click="NavCategory_Click" Tag="horror"/>
                        <MenuFlyoutItem Text="Indie" Click="NavCategory_Click" Tag="indie"/>
                        <MenuFlyoutItem Text="Multiplayer" Click="NavCategory_Click" Tag="multiplayer"/>
                        <MenuFlyoutItem Text="Open World" Click="NavCategory_Click" Tag="open-world"/>
                        <MenuFlyoutItem Text="Racing" Click="NavCategory_Click" Tag="racing"/>
                        <MenuFlyoutItem Text="Shooters" Click="NavCategory_Click" Tag="shooting"/>
                        <MenuFlyoutItem Text="Simulation" Click="NavCategory_Click" Tag="simulation"/>
                        <MenuFlyoutItem Text="Sports" Click="NavCategory_Click" Tag="sports"/>
                        <MenuFlyoutItem Text="Strategy" Click="NavCategory_Click" Tag="strategy"/>
                        <MenuFlyoutItem Text="Virtual Reality" Click="NavCategory_Click" Tag="vr"/>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>

            <AppBarButton Icon="Favorite" Label="Top Games" Click="NavTopGames_Click"/>

            <AppBarButton Icon="Help" Label="FAQ">
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="All FAQs" Click="NavFaq_Click" Tag="faq"/>
                        <MenuFlyoutItem Text="How to Run Games" Click="NavFaq_Click" Tag="how-to-run-games"/>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>

            <AppBarButton Icon="Message" Label="Discord" Click="NavDiscord_Click"/>
        </CommandBar>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <AutoSuggestBox x:Name="SearchBox"
                                PlaceholderText="Search games on SteamRIP..."
                                QueryIcon="Find"
                                Width="300"
                                TextMemberPath="name"
                                TextChanged="SearchBox_TextChanged"
                                SuggestionChosen="SearchBox_SuggestionChosen"
                                QuerySubmitted="SearchBox_QuerySubmitted">
                    <AutoSuggestBox.ItemTemplate>
                        <DataTemplate x:DataType="core:JsonGameEntry">
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border CornerRadius="4" Width="36" Height="48" HorizontalAlignment="Left">
                                    <Image Source="{x:Bind cover_image}" Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <TextBlock Text="{x:Bind name}" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind genre_string}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </AutoSuggestBox.ItemTemplate>
                </AutoSuggestBox>
                <Button Content="Search" Click="SearchBtn_Click" Style="{StaticResource AccentButtonStyle}"/>
                <StackPanel x:Name="PaginationPanel" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="16,0,0,0"/>

            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="2" Padding="0,0,16,0">
            <ItemsControl x:Name="ResultsGrid" Margin="0,0,0,24">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="core:GameGroup">
                        <StackPanel Margin="0,0,0,24">
                            <TextBlock Text="{x:Bind Title}" FontSize="24" FontWeight="Bold" Margin="6,0,0,12"
                                       Visibility="{x:Bind HasTitle, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                            <GridView ItemsSource="{x:Bind Games}" SelectionMode="None">
                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="core:SearchResult">
                                        <Grid Width="186" Margin="6" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="254"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Border CornerRadius="8,8,0,0" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" Height="254">
                                                <Button Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                        BorderThickness="0" Background="Transparent"
                                                        Click="CoverImage_Click" DataContext="{x:Bind}">
                                                    <Image Stretch="UniformToFill">
                                                        <Image.Source>
                                                            <BitmapImage UriSource="{x:Bind ImageUrl, Mode=OneWay}" />
                                                        </Image.Source>
                                                    </Image>
                                                </Button>
                                            </Border>

                                            <StackPanel Grid.Row="1" Padding="10" Spacing="4">
                                                <TextBlock Text="{x:Bind Title}" FontWeight="Bold" FontSize="13"
                                                           TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" ToolTipService.ToolTip="{x:Bind Title}"/>
                                                <TextBlock Text="{x:Bind DateString}" FontSize="11"
                                                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>

                                                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0" Height="22">
                                                    <Border Background="#2E7D32" BorderBrush="#4CAF50" BorderThickness="1" CornerRadius="4" Padding="6,2"
                                                            Visibility="{x:Bind IsOnline, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="ONLINE" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                                    </Border>
                                                    <Border Background="#C62828" BorderBrush="#EF5350" BorderThickness="1" CornerRadius="4" Padding="6,2"
                                                            Visibility="{x:Bind IsOnline, Mode=OneWay, Converter={StaticResource InvertedBoolToVis}}">
                                                        <TextBlock Text="OFFLINE" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                                    </Border>
                                                    <Border Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" BorderBrush="{ThemeResource SystemControlBackgroundBaseMediumLowBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2"
                                                            Visibility="{x:Bind HasDownloadsTag, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                            <FontIcon Glyph="&#xE896;" FontSize="10" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                                            <TextBlock Text="{x:Bind DownloadsTagText, Mode=OneWay}" FontSize="10" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>

                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Grid.Column="0">
                                                        <Button FontSize="11" Padding="6,4" HorizontalAlignment="Stretch"
                                                                Style="{StaticResource AccentButtonStyle}"
                                                                Click="QuickDownload_Click"
                                                                DataContext="{x:Bind}">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <FontIcon Glyph="&#xE896;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="12"/>
                                                                <TextBlock Text="{x:Bind DownloadButtonText, Mode=OneWay}"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </Grid>

                                                    <Button Grid.Column="1" Margin="4,0,0,0" Padding="8,4"
                                                            Click="Preview_Click"
                                                            DataContext="{x:Bind}"
                                                            ToolTipService.ToolTip="Game Page &amp; Properties">
                                                        <SymbolIcon Symbol="Link"/>
                                                    </Button>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid x:Name="PropertiesOverlayDimmer" Background="#CC000000" Visibility="Collapsed" Grid.RowSpan="3"/>
        <Grid x:Name="PropertiesDialog" Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
              MaxWidth="1200" Margin="24" Height="800" CornerRadius="12" Visibility="Collapsed" Grid.RowSpan="3"
              HorizontalAlignment="Stretch" VerticalAlignment="Center"
              BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderThickness="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Height="120" CornerRadius="12,12,0,0">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF1A1A2E" Offset="0"/>
                        <GradientStop Color="#FF16213E" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <StackPanel Orientation="Horizontal" Margin="24,0" VerticalAlignment="Center" Spacing="20">
                    <Border Width="160" Height="90" CornerRadius="8" Background="#20FFFFFF">
                        <Image x:Name="PropsHeaderImage" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <TextBlock x:Name="PropsTitle" Text="Game Properties" FontSize="28" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="PropsSubtitle" Text="SteamRIP Original Release" FontSize="14" Opacity="0.7" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="24,20,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Margin="0,0,16,0" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
                    <StackPanel Spacing="24">

                        <Border x:Name="HowToRunSection" Visibility="Collapsed"
                                Background="#1A0078D4" BorderBrush="#330078D4"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE73E;" FontSize="18" Foreground="#0078D4"/>
                                    <TextBlock Text="Installation Notes" FontWeight="Bold" FontSize="16"/>
                                </StackPanel>
                                <WebView2 x:Name="HowToRunWebView" Height="200" HorizontalAlignment="Stretch"
                                          DefaultBackgroundColor="Transparent"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Spacing="12">
                            <TextBlock Text="📋 Technical Details" FontWeight="SemiBold" FontSize="16" Opacity="0.8"/>
                            <ItemsControl x:Name="GameInfoList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Key}" FontWeight="SemiBold" Opacity="0.6" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap" FontSize="12"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="12">
                            <TextBlock Text="⚙️ System Requirements" FontWeight="SemiBold" FontSize="16" Opacity="0.8"/>
                                <ItemsControl x:Name="RequirementsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Icon}" FontSize="12" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="{Binding Key}" FontWeight="SemiBold" FontSize="12"/>
                                                    <TextBlock Text="{Binding Value}" TextWrapping="Wrap" FontSize="11" Opacity="0.7"/>
                                                </StackPanel>

                                                <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="4"
                                                        VerticalAlignment="Top" HorizontalAlignment="Right"
                                                        Visibility="{Binding HasRankDiff, Converter={StaticResource BoolToVis}}">
                                                    <FontIcon Glyph="&#xE946;" Opacity="0.5" FontSize="14"/>
                                                    <ToolTipService.ToolTip>
                                                        <ToolTip Content="{Binding RankText}" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"/>
                                                    </ToolTipService.ToolTip>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            <ProgressRing x:Name="RequirementsLoading" IsActive="False" Width="24" Height="24" HorizontalAlignment="Center" Margin="0,10"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" Padding="12,8" CornerRadius="8,8,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Globe" Opacity="0.6"/>
                            <TextBlock Text="SteamRIP Page Preview" FontSize="12" FontWeight="SemiBold" Opacity="0.6"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" BorderBrush="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                            BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                        <WebView2 x:Name="LiveChatWebView" NavigationCompleted="LiveChatWebView_NavigationCompleted"/>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" Padding="24,16" CornerRadius="0,0,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Click="OpenInBrowser_Click"
                            Background="Transparent" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="World"/>
                            <TextBlock Text="View Original Page"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Button Grid.Column="1" Content="Close Properties" Click="PropsCancelBtn_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="24,8"/>
            </Grid>
        </Grid>

        <WebView2 x:Name="DownloadInterceptor" Visibility="Collapsed" Width="0" Height="0"/>

        <ProgressRing x:Name="LoadingRing" Grid.Row="2" Width="50" Height="50"
                      IsActive="False" VerticalAlignment="Center" HorizontalAlignment="Center"/>

    </Grid>
</Page>