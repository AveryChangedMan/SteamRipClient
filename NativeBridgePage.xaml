<Page
    x:Class="SteamRipApp.NativeBridgePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <SolidColorBrush x:Key="SteamPurple" Color="#733d91"/>
        <SolidColorBrush x:Key="DeepPurple" Color="#4b367c"/>
    </Page.Resources>

    <Grid>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1f2024" Offset="0"/>
                <GradientStop Color="#17141f" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer Padding="32">
            <StackPanel Spacing="32" MaxWidth="1000" HorizontalAlignment="Left">

                <StackPanel Spacing="4">
                    <TextBlock Text="Steam Integration" FontSize="36" FontWeight="Bold" Foreground="{StaticResource SteamPurple}"/>
                    <TextBlock Text="BRIDGE SERVICE MANAGEMENT" FontSize="12" FontWeight="Bold" Opacity="0.5" CharacterSpacing="100"/>
                    <TextBlock Text="Manage and monitor the background service that connects your library to the Steam client interface."
                               Style="{StaticResource BodyTextBlockStyle}" Opacity="0.8" Margin="0,8,0,0"/>
                </StackPanel>

                <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="16" Padding="24"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="24">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE961;" Foreground="{StaticResource SteamPurple}" FontSize="20"/>
                                <TextBlock Text="Service Controller" FontWeight="Bold" FontSize="20"/>
                            </StackPanel>

                            <Grid ColumnSpacing="40">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center">
                                    <ToggleSwitch x:Name="ServiceToggle" Header="System Integration"
                                                  Toggled="ServiceToggle_Toggled"
                                                  OnContent="Active &amp; Ready" OffContent="Service Suspended"
                                                  FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="8">
                                    <TextBlock Text="Target Steam Account" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                    <ComboBox x:Name="UserSelector" Width="280" Height="40"
                                              SelectionChanged="UserSelector_SelectionChanged"
                                              PlaceholderText="Detecting accounts..."
                                              CornerRadius="8">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnSpacing="12" Padding="4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <FontIcon Glyph="&#xE77B;" FontSize="16" Opacity="0.7"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding PersonaName}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding AccountId}" Foreground="Gray" FontSize="10"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Button Grid.Column="1" Click="KillService_Click"
                                VerticalAlignment="Bottom" Height="40" Padding="20,0"
                                CornerRadius="8" Background="Transparent" BorderBrush="#FF5555" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE777;" FontSize="14" Foreground="#FF5555"/>
                                <TextBlock Text="Reset All Integrations" Foreground="#FF5555" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="16" Padding="24"
                        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderThickness="1">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="500"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xECAD;" Foreground="Gold" FontSize="20"/>
                                <TextBlock Text="Live Activity Monitor" FontWeight="Bold" FontSize="20"/>
                            </StackPanel>
                            <TextBlock Text="CONSOLE LOG" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Opacity="0.4" CharacterSpacing="50"/>
                        </Grid>

                        <Border Grid.Row="1" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" CornerRadius="12" Padding="16,8">
                            <ScrollViewer HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Hidden" VerticalScrollMode="Disabled">
                                <StackPanel Orientation="Horizontal" Spacing="20">
                                    <CheckBox x:Name="Filter_LAUNCHER" Content="Launcher" IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed" Foreground="OrangeRed" FontWeight="SemiBold"/>
                                    <CheckBox x:Name="Filter_SYSTEM" Content="System" IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed" Foreground="Cyan" FontWeight="SemiBold"/>
                                    <CheckBox x:Name="Filter_CONFIG" Content="Config" IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed" Foreground="MediumPurple" FontWeight="SemiBold"/>
                                    <CheckBox x:Name="Filter_PATCH" Content="Patch" IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed" Foreground="Gold" FontWeight="SemiBold"/>
                                    <CheckBox x:Name="Filter_PROCESS" Content="Process" IsChecked="False" Checked="Filter_Changed" Unchecked="Filter_Changed" Foreground="LightSalmon" FontWeight="SemiBold"/>
                                    <CheckBox x:Name="Filter_DISK" Content="Disk" IsChecked="False" Checked="Filter_Changed" Unchecked="Filter_Changed" Foreground="LightGreen" FontWeight="SemiBold"/>
                                    <CheckBox x:Name="Filter_INTERFACE" Content="Interface" IsChecked="False" Checked="Filter_Changed" Unchecked="Filter_Changed" Foreground="HotPink" FontWeight="SemiBold"/>
                                    <CheckBox x:Name="Filter_GENERAL" Content="General" IsChecked="False" Checked="Filter_Changed" Unchecked="Filter_Changed" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Row="2" Background="#11000000" CornerRadius="12"
                                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderThickness="1">
                            <ListView x:Name="LogList" Padding="16" SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="MinHeight" Value="24"/>
                                        <Setter Property="Padding" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="13"
                                                   TextWrapping="Wrap" Opacity="0.9"
                                                   Foreground="{ThemeResource SystemControlPageTextBaseHighBrush}"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>