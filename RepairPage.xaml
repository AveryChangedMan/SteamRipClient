<Page
    x:Class="SteamRipApp.RepairPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SteamRipApp"
    xmlns:core="using:SteamRipApp.Core">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Spacing="4" Margin="0,0,0,24">
            <TextBlock Text="Repair &amp; Integrity" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Verify game files, restore missing or corrupted data, and manage integrity snapshots." Opacity="0.6"/>
        </StackPanel>

        <GridView x:Name="RepairGameGrid" Grid.Row="1"
                  SelectionMode="None"
                  IsItemClickEnabled="False">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="core:GameFolder">
                    <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                            CornerRadius="12" Width="360" Margin="0,0,16,16" Padding="0">
                        <Grid>
                            <StackPanel Spacing="12" Padding="16">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border CornerRadius="8" Width="50" Height="50" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                                        <Image Source="{Binding LocalImagePath}" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Drive}" Opacity="0.6" FontSize="12"/>
                                    </StackPanel>
                                </Grid>

                                <Rectangle Height="1" Fill="{ThemeResource SystemControlBackgroundBaseLowBrush}" Opacity="0.1"/>

                                <TextBlock Text="Integrity Actions" FontWeight="SemiBold" FontSize="12" Opacity="0.5"/>

                                <Button Content="🛠 Repair Game"
                                        HorizontalAlignment="Stretch"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Click="RepairGame_Click" Tag="{Binding RootPath}"/>

                            </StackPanel>

                            <Border Background="#F20F0F1B" CornerRadius="12"
                                    Visibility="{Binding IsInProgress, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Canvas.ZIndex="10">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" Padding="20">
                                    <TextBlock Text="{Binding ProgressPhase}" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#0078D4"/>
                                    <Grid Height="60" Width="60">
                                        <ProgressRing IsActive="True" Foreground="#0078D4" Width="60" Height="60"/>
                                        <TextBlock Text="{Binding ProgressPercentage, Converter={StaticResource PercentStringConverter}}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   FontSize="12" FontWeight="Bold"/>
                                    </Grid>
                                    <TextBlock Text="{Binding ProgressDetails}" FontSize="11" Opacity="0.8" TextAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <ProgressRing x:Name="LoadingRing" Grid.Row="1" Width="50" Height="50" IsActive="False" VerticalAlignment="Center" HorizontalAlignment="Center"/>
    </Grid>
</Page>