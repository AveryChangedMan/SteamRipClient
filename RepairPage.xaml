<Page
    x:Class="SteamRipApp.RepairPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SteamRipApp"
    xmlns:core="using:SteamRipApp.Core">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Spacing="4" Margin="0,0,0,24">
            <TextBlock Text="Repair &amp; Integrity" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Verify game files, restore missing or corrupted data, and manage integrity snapshots." Opacity="0.6"/>
        </StackPanel>

        <GridView x:Name="RepairGameGrid" Grid.Row="1"
                  SelectionMode="None"
                  IsItemClickEnabled="False">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="core:GameFolder">
                    <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                            CornerRadius="12" Width="360" Margin="0,0,16,16" Padding="16">
                        <StackPanel Spacing="12">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border CornerRadius="8" Width="50" Height="50" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                                    <Image Source="{Binding LocalImagePath}" Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Drive}" Opacity="0.6" FontSize="12"/>
                                </StackPanel>
                            </Grid>

                            <Rectangle Height="1" Fill="{ThemeResource SystemControlBackgroundBaseLowBrush}" Opacity="0.1"/>

                            <TextBlock Text="Integrity Actions" FontWeight="SemiBold" FontSize="12" Opacity="0.5"/>

                            <Button Content="🛠 Repair Game"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="RepairGame_Click" Tag="{Binding RootPath}"/>

                            <StackPanel Spacing="8"
                                        Visibility="{Binding IsAdvancedRepairVisible, Converter={StaticResource BoolToVisibilityConverter}}">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Content="📸 Snapshot"
                                            HorizontalAlignment="Stretch" Margin="0,0,4,0"
                                            Click="CreateSnapshot_Click" Tag="{Binding RootPath}"
                                            ToolTipService.ToolTip="Create a new integrity snapshot of the current files."/>

                                    <ComboBox Grid.Column="1"
                                              HorizontalAlignment="Stretch" Margin="4,0,0,0"
                                              PlaceholderText="Official Rip Map"
                                              ItemsSource="{Binding Snapshots}"
                                              SelectedItem="{Binding SelectedSnapshot, Mode=TwoWay}"/>
                                </Grid>

                                <Button Content="🗑 Reset Integrity Data"
                                        HorizontalAlignment="Stretch"
                                        FontSize="11" Opacity="0.7"
                                        Foreground="OrangeRed" BorderThickness="0"
                                        Click="ResetHashes_Click" Tag="{Binding RootPath}"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>