<Page
    x:Class="SteamRipApp.DownloadsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SteamRipApp"
    xmlns:core="using:SteamRipApp.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <core:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <core:PhaseToColorConverter x:Key="PhaseToColorConverter" />
        <core:SafeUriConverter x:Key="SafeUriConverter" />
    </Page.Resources>
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="&#x1F4E5; Active Downloads" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,20"/>
        <ListView x:Name="DownloadsList" Grid.Row="1" SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="core:ActiveDownloadMetadata">
                    <Grid Padding="16,12" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                          CornerRadius="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border CornerRadius="4" Width="64" Height="40" Margin="0,0,12,0" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                            <Image Source="{x:Bind ImageUrl, Mode=OneWay, Converter={StaticResource SafeUriConverter}}" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind Title, Mode=OneWay}" FontWeight="SemiBold" FontSize="14"/>
                                <Border CornerRadius="4" Padding="6,2"
                                        Background="{x:Bind Phase, Mode=OneWay, Converter={StaticResource PhaseToColorConverter}}">
                                    <TextBlock Text="{x:Bind Phase, Mode=OneWay}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="White"/>
                                </Border>
                                <Border CornerRadius="4" Padding="6,2" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderBrush="{ThemeResource SystemControlBackgroundBaseMediumBrush}" BorderThickness="1">
                                    <TextBlock Text="{x:Bind Source, Mode=OneWay}" FontSize="9" FontWeight="Bold" Opacity="0.7"/>
                                </Border>
                            </StackPanel>
                            <ProgressBar x:Name="MainProgressBar"
                                         Value="{x:Bind Percentage, Mode=OneWay}"
                                         Minimum="0" Maximum="100"
                                         Height="6" CornerRadius="3"/>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}">
                                    <Binding Path="Percentage" Mode="OneWay" /> <Run Text="%"/>
                                </TextBlock>
                                <TextBlock Text="{x:Bind Status, Mode=OneWay}" FontSize="12"
                                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                            <Button x:Name="PauseBtn"
                                    Width="36" Height="36" Padding="0" BorderThickness="0"
                                    ToolTipService.ToolTip="Pause / Resume"
                                    Click="PauseResume_Click"
                                    Tag="{x:Bind DestPath, Mode=OneWay}">
                                <SymbolIcon x:Name="PauseIcon" Symbol="Pause"/>
                            </Button>
                            <Button Width="36" Height="36" Padding="0" BorderThickness="0"
                                    ToolTipService.ToolTip="Cancel and delete"
                                    Click="Cancel_Click"
                                    Tag="{x:Bind DestPath, Mode=OneWay}">
                                <SymbolIcon Symbol="Delete"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <StackPanel x:Name="EmptyLabel" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="12" Visibility="Collapsed">
            <SymbolIcon Symbol="Download"/>
            <TextBlock Text="No active downloads." Style="{StaticResource SubtitleTextBlockStyle}"/>
        </StackPanel>
    </Grid>
</Page>

