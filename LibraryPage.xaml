<Page
    x:Class="SteamRipApp.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SteamRipApp"
    xmlns:core="using:SteamRipApp.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <core:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <core:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter" />
        <core:SafeUriConverter x:Key="SafeUriConverter" />
        <core:RunningToColorConverter x:Key="RunningToColorConverter" />
        <core:LaunchButtonBrushConverter x:Key="LaunchButtonBrushConverter" />
        <core:RunningToStopWarningConverter x:Key="RunningToStopWarningConverter" />
        <core:RunningToBorderThicknessConverter x:Key="RunningToBorderThicknessConverter" />
        <core:PercentStringConverter x:Key="PercentStringConverter" />

        <Storyboard x:Key="PulseAnimation">
            <DoubleAnimation
                Storyboard.TargetProperty="Opacity"
                From="0.4" To="0.8" Duration="0:0:1.5"
                AutoReverse="True" RepeatBehavior="Forever" />
        </Storyboard>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Padding="24,12,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="RefreshBtn" Click="RefreshBtn_Click" Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Refresh"/>
                    <TextBlock Text="Refresh Library"/>
                </StackPanel>
            </Button>
            <TextBlock x:Name="StatusLabel" Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>

        </Grid>

        <GridView x:Name="GameGrid"
                  Grid.Row="1"
                  Padding="24,12,24,24"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="GameGrid_ItemClick">
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Border Width="186" Margin="6" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="254"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Launch Game" Click="Launch_Click" Tag="{Binding RootPath}">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Play"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Properties" Click="Properties_Click" Tag="{Binding RootPath}">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Link"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Game Configuration" Click="ConfigBtn_Click" Tag="{Binding RootPath}">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Setting"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="Open Directory" Click="OpenDirectory_Click" Tag="{Binding RootPath}">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Folder"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Create Shortcut" Click="CreateShortcut_Click" Tag="{Binding RootPath}">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Link"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Repair Game" Click="Repair_Click" Tag="{Binding RootPath}" Visibility="{Binding IsRepairable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Repair"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Move Installation" Click="MoveInstall_Click" Tag="{Binding RootPath}" Visibility="{Binding ShowMoveButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Forward"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="Add to Steam Library" Click="AddToSteam_Click" Tag="{Binding RootPath}">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Globe"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="Delete Game" Click="Uninstall_Click" Tag="{Binding RootPath}" Foreground="Red">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Delete" Foreground="Red"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Grid.ContextFlyout>

                        <Grid Grid.RowSpan="2" Canvas.ZIndex="10"
                              Visibility="{Binding ShowProgressOverlay, Converter={StaticResource BooleanToVisibilityConverter}}"
                              CornerRadius="8"
                              Background="Transparent"
                              IsHitTestVisible="True"
                              ContextFlyout="{x:Null}">

                            <Border Background="#F20F0F1B" CornerRadius="8">
                                <Border.Child>
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Padding="16" Spacing="20">

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding ProgressPhase}"
                                                           HorizontalAlignment="Center"
                                                           FontWeight="Bold"
                                                           FontSize="15"
                                                           Foreground="#0078D4"
                                                           TextAlignment="Center"/>
                                                <ProgressBar Value="{Binding ProgressPercentage}"
                                                             Maximum="100"
                                                             Height="3"
                                                             CornerRadius="1.5"
                                                             Foreground="#0078D4"
                                                             Background="#1AFFFFFF"/>
                                            </StackPanel>

                                            <Grid Height="50" Width="50" HorizontalAlignment="Center">
                                                <ProgressRing IsActive="True" Foreground="#0078D4" Width="50" Height="50"/>
                                                <TextBlock Text="{Binding ProgressPercentage, Converter={StaticResource PercentStringConverter}}"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                                           FontSize="10" FontWeight="Bold" Foreground="White" Opacity="0.9"/>
                                            </Grid>

                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding ProgressDetails}"
                                                           FontSize="10"
                                                           Foreground="White"
                                                           Opacity="0.7"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="40"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding EstimatedTime}"
                                                           FontSize="9" Foreground="#0078D4"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Visibility="{Binding EstimatedTime, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border.Child>
                            </Border>

                            <Border BorderBrush="#400078D4" BorderThickness="1.5" CornerRadius="8"/>
                        </Grid>
                        <Border Background="#1a1a2e" CornerRadius="8,8,0,0">
                            <Grid>
                                <Image Stretch="Uniform" Source="{Binding LocalImagePath, Converter={StaticResource SafeUriConverter}}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       MaxHeight="254"/>

                                <Button x:Name="UpdateBtn"
                                        VerticalAlignment="Top" HorizontalAlignment="Left"
                                        Margin="8" Padding="10,5"
                                        Foreground="Black"
                                        FontSize="10" FontWeight="Bold" CornerRadius="4"
                                        Visibility="{Binding HasVersionUpdate, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Click="UpdateGame_Click" Tag="{Binding RootPath}">
                                    <Button.Resources>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Grid x:Name="RootGrid" Background="Transparent" CornerRadius="4">
                                                            <VisualStateManager.VisualStateGroups>
                                                                <VisualStateGroup x:Name="CommonStates">
                                                                    <VisualState x:Name="Normal"/>
                                                                    <VisualState x:Name="PointerOver">
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetName="GlowBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1"/>
                                                                        </Storyboard>
                                                                    </VisualState>
                                                                    <VisualState x:Name="Pressed">
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Opacity" To="0.8" Duration="0:0:0.1"/>
                                                                        </Storyboard>
                                                                    </VisualState>
                                                                </VisualStateGroup>
                                                            </VisualStateManager.VisualStateGroups>
                                                            <Border x:Name="BackgroundBorder" CornerRadius="4">
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                        <GradientStop Color="#FFFFD700" Offset="0.0"/>
                                                                        <GradientStop Color="#FFFFA500" Offset="1.0"/>
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                            </Border>
                                                            <Border x:Name="GlowBorder" BorderBrush="White" BorderThickness="1" CornerRadius="4" Opacity="0"/>
                                                            <ContentPresenter x:Name="ContentPresenter"
                                                                              Content="{TemplateBinding Content}"
                                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                              Margin="{TemplateBinding Padding}"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Resources>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE777;" FontSize="12" Foreground="Black"/>
                                        <TextBlock Text="UPDATE AVAILABLE" Foreground="Black"/>
                                    </StackPanel>
                                </Button>

                                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4"
                                        Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" BorderThickness="0"
                                        Click="FindImage_Click" Tag="{Binding RootPath}" ToolTipService.ToolTip="Find Cover Image">
                                    <SymbolIcon Symbol="Find" Foreground="{ThemeResource SystemControlPageTextBaseHighBrush}"/>
                                </Button>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="1" Padding="10,10,10,10" Spacing="4">

                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                                <TextBlock Text="⚠️" FontSize="12" VerticalAlignment="Center"
                                           Visibility="{Binding HasVersionUpdate, Converter={StaticResource BooleanToVisibilityConverter}}"
                                           ToolTipService.ToolTip="A newer version is available on the SteamRIP page."/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{Binding IsMoving, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="📦 Moving..." FontSize="10" FontWeight="SemiBold" Foreground="Orange"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{Binding IsMoving, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                                <Border Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" Padding="4,0" CornerRadius="2">
                                    <TextBlock Text="{Binding Drive}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Text="{Binding DisplayVersion}" FontSize="9" Opacity="0.7" VerticalAlignment="Center" Margin="6,0,0,0"
                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" MaxWidth="120"
                                           ToolTipService.ToolTip="{Binding DisplayVersion}"/>
                            </StackPanel>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Content="{Binding LaunchButtonText}"
                                            Background="{Binding Converter={StaticResource LaunchButtonBrushConverter}}"
                                            BorderBrush="Red"
                                            BorderThickness="{Binding IsRunning, Converter={StaticResource RunningToBorderThicknessConverter}}"
                                            HorizontalAlignment="Stretch"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="Launch_Click" Tag="{Binding RootPath}"
                                            Visibility="{Binding ShowLaunchButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            FontSize="11"
                                            ToolTipService.ToolTip="{Binding IsRunning, Converter={StaticResource RunningToStopWarningConverter}}"/>

                                    <Button Grid.Column="1" Margin="4,0,0,0" Padding="8,4"
                                            Click="Properties_Click" Tag="{Binding RootPath}"
                                            Visibility="{Binding IsMoving, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
                                            ToolTipService.ToolTip="Game Page &amp; Properties">
                                        <SymbolIcon Symbol="Link"/>
                                    </Button>
                                </Grid>
                        </StackPanel>

                        <Border Visibility="{Binding IsRedistMissing, Converter={StaticResource BooleanToVisibilityConverter}}"
                                HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8" Padding="4,2" Background="DarkRed" CornerRadius="4">
                            <TextBlock Text="⚠️ REDIST MISSING" FontSize="10" Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <Grid x:Name="RedistOverlay" Background="#80000000" Visibility="Collapsed" Grid.RowSpan="2"/>
        <Grid x:Name="RedistPanel" Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
              Width="450" MaxHeight="600" CornerRadius="12" Padding="24" Visibility="Collapsed" Grid.RowSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                <SymbolIcon Symbol="Setting" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                <TextBlock Text="Missing Requirements" FontSize="20" FontWeight="Bold"/>
            </StackPanel>

            <ListView x:Name="RedistMissingList" Grid.Row="1" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,12" BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding FriendlyName}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding FileName}" FontSize="10" Opacity="0.6"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Open Installer" Click="OpenRedistInstaller_Click" Tag="{Binding FullPath}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Close" Click="RedistPanelClose_Click"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="ImageSearchOverlay" Background="#80000000" Visibility="Collapsed" Grid.RowSpan="2"/>
        <Grid x:Name="ImageSearchDialog" Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
              Width="450" Height="500" CornerRadius="8" Padding="24" Visibility="Collapsed" Grid.RowSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Find Game Cover" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

            <StackPanel Grid.Row="1" Spacing="12">
                <AutoSuggestBox x:Name="DialogSearchBox" PlaceholderText="Search SteamRIP for covers..."
                                QuerySubmitted="DialogSearchBox_QuerySubmitted"/>

                <ListView x:Name="DialogResultsList" Height="300" SelectionMode="Single"
                          SelectionChanged="DialogResultsList_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="12" Padding="8">
                                <Image Width="80" Height="45" Stretch="UniformToFill" Source="{Binding ImageUrl}"/>
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <ProgressRing x:Name="DialogLoadingRing" IsActive="False"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="DialogCancelBtn" Content="Cancel" Click="DialogCancelBtn_Click"/>
                <Button x:Name="DialogSetCoverBtn" Content="Set as Cover" Style="{StaticResource AccentButtonStyle}" IsEnabled="False" Click="DialogSetCoverBtn_Click"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="PropertiesOverlayDimmer" Background="#80000000" Visibility="Collapsed" Grid.RowSpan="2"/>
        <Grid x:Name="PropertiesDialog" Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
              Width="1100" Height="700" CornerRadius="8" Visibility="Collapsed" Grid.RowSpan="2"
              HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="PropsTitle" Text="Game Properties" FontSize="20" FontWeight="Bold" Margin="24,20,24,0"/>

            <Grid Grid.Row="1" Margin="24,12,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="310"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Margin="0,0,8,0" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="📋 Game Info" FontWeight="SemiBold" FontSize="15"/>
                        <StackPanel x:Name="GameInfoList" Spacing="6"/>

                        <Button Content="🔗 Link Different Page" Click="ManualLinkBtn_Click"
                                HorizontalAlignment="Stretch" Margin="0,4,0,0"/>

                        <TextBlock Text="⚙️ System Requirements" FontWeight="SemiBold" FontSize="15" Margin="0,12,0,0"/>
                        <StackPanel x:Name="RequirementsList" Spacing="6"/>
                        <ProgressRing x:Name="RequirementsLoading" IsActive="False" Width="24" Height="24" HorizontalAlignment="Left"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="1" BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderThickness="1" CornerRadius="4">
                    <WebView2 x:Name="LiveChatWebView" NavigationCompleted="LiveChatWebView_NavigationCompleted"/>
                </Border>
            </Grid>

            <Button Grid.Row="2" Content="Close" Click="PropsCancelBtn_Click"
                    HorizontalAlignment="Right" Margin="24,12,24,16"/>
        </Grid>

        <Grid x:Name="LinkSearchOverlay" Background="#A0000000" Visibility="Collapsed" Grid.RowSpan="2"/>
        <Border x:Name="LinkSearchDialog" Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
               Width="520" CornerRadius="12" Padding="0" Visibility="Collapsed" Grid.RowSpan="2"
               HorizontalAlignment="Center" VerticalAlignment="Center"
               BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="12,12,0,0" Padding="20,16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="🔗 Link SteamRIP Page" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="LinkDialogSubtitle" Text="Search for the correct game page to link." FontSize="12" Foreground="White" Opacity="0.8"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Padding="20,16,20,8">
                    <AutoSuggestBox x:Name="LinkSearchBox" PlaceholderText="Search for the correct game page..."
                                    QuerySubmitted="LinkSearchBox_QuerySubmitted"/>
                </Border>

                <Border Grid.Row="2" MaxHeight="320" Padding="8,0">
                    <ScrollViewer>
                        <StackPanel>
                            <ListView x:Name="LinkResultsList" SelectionMode="Single"
                                      SelectionChanged="LinkResultsList_SelectionChanged">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="4,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border CornerRadius="4">
                                                <Image Width="80" Height="48" Stretch="UniformToFill" Source="{Binding ImageUrl}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" Margin="12,0,0,0">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding DateString}" FontSize="11" Opacity="0.6"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <ProgressRing x:Name="LinkLoadingRing" IsActive="False" HorizontalAlignment="Center" Margin="0,8"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="3" Padding="20,12" BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                        <Button Content="Cancel" Click="LinkCancelBtn_Click" Padding="16,8"/>
                        <Button x:Name="LinkConfirmBtn" Content="Link This Page" Style="{StaticResource AccentButtonStyle}" IsEnabled="False" Click="LinkConfirmBtn_Click" Padding="16,8"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ProgressRing x:Name="LoadingRing" Grid.Row="1" Width="50" Height="50" IsActive="False" VerticalAlignment="Center" HorizontalAlignment="Center"/>

    </Grid>
</Page>