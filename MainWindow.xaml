<Window
    x:Class="SteamRipApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SteamRipApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SteamRIP Engine v1.6.0.5">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Background="Transparent" Height="48" VerticalAlignment="Top" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Padding="12,0,0,0">
                <Image x:Name="TitleBarIcon" Source="Assets/app_icon.ico" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,0,0"/>
                <TextBlock Text="SteamRIP Engine" VerticalAlignment="Center" Margin="12,0,0,0" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        PaneDisplayMode="Left"
                        IsBackButtonVisible="Collapsed"
                        ItemInvoked="NavView_ItemInvoked">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Icon="Home" Tag="home"/>
                <NavigationViewItem x:Name="SteamNavItem" Content="Steam (Beta)" Icon="Globe" Tag="steam"/>
                <NavigationViewItem Content="Downloads" Icon="Download" Tag="downloads"/>
                <NavigationViewItem Content="Library" Icon="Library" Tag="library"/>

                <NavigationViewItem Content="Redist Cleanup" Icon="Delete" Tag="cleanup"/>
                <NavigationViewItem Content="Help" Icon="Help" Tag="help"/>
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <StackPanel Orientation="Vertical">

                    <StackPanel x:Name="HashingStatusArea" Orientation="Vertical" Padding="16,0,16,16" Spacing="8" Visibility="Collapsed">
                        <TextBlock Text="Verification Active" FontSize="11" FontWeight="Bold" Opacity="0.6"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ProgressRing IsActive="True" Width="16" Height="16"/>
                            <TextBlock x:Name="HashingStatusText" Text="Hashing..." FontSize="12" Opacity="0.8" TextWrapping="Wrap"/>
                            <Button Click="StopHashing_Click" Background="Transparent" BorderThickness="0" Padding="4" VerticalAlignment="Center">
                                <SymbolIcon Symbol="Stop"/>
                            </Button>
                        </StackPanel>
                        <ProgressBar x:Name="HashingProgressBar" Minimum="0" Maximum="100" Height="4" IsIndeterminate="False"/>
                    </StackPanel>

                    <StackPanel x:Name="GlobalMoveStatus" Orientation="Vertical" Padding="16,0,16,16" Spacing="8" Visibility="Collapsed">
                        <TextBlock Text="Process Active" FontSize="11" FontWeight="Bold" Opacity="0.6"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ProgressRing IsActive="True" Width="16" Height="16"/>
                            <TextBlock x:Name="GlobalMoveText" Text="Moving Game..." FontSize="12" Opacity="0.8" TextWrapping="Wrap"/>
                            <Button x:Name="GlobalCancelBtn" Click="GlobalCancelMove_Click" Background="Transparent" BorderThickness="0" Padding="4" VerticalAlignment="Center">
                                <SymbolIcon Symbol="Stop"/>
                            </Button>
                        </StackPanel>
                        <ProgressBar x:Name="GlobalProgressBar" Height="4" Minimum="0" Maximum="100" IsIndeterminate="False"/>
                    </StackPanel>
                </StackPanel>
            </NavigationView.PaneFooter>

            <NavigationView.Content>
                <Frame x:Name="ContentFrame" Padding="24" IsNavigationStackEnabled="True"/>
            </NavigationView.Content>
        </NavigationView>

        <Border x:Name="ConfigOverlay"
                Visibility="Collapsed"
                Grid.RowSpan="2"
                Background="{ThemeResource SystemControlPageBackgroundMediumAltMediumBrush}">
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="600" Padding="32" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="ConfigTitle" Text="Game Configuration" Style="{StaticResource TitleTextBlockStyle}"/>
                    <ScrollViewer MaxHeight="400">
                        <StackPanel x:Name="ConfigOptionsList" Spacing="8">

                        </StackPanel>
                    </ScrollViewer>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="Save" Click="SaveConfig_Click" Style="{StaticResource AccentButtonStyle}" Width="80"/>
                        <Button Content="Cancel" Click="CancelConfig_Click" Width="80"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        <Border x:Name="SetupOverlay"
                Visibility="Collapsed"
                Grid.RowSpan="2"
                Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="500" Width="500" Padding="40" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="16" BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderThickness="1">
                <StackPanel Spacing="24">
                    <TextBlock Text="First Launch Setup" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" FontWeight="Bold"/>

                    <StackPanel x:Name="SetupStepList" Spacing="16">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon x:Name="Step1Icon" Glyph="&#xE73E;" FontSize="16" Foreground="Gray"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Download Directory" FontWeight="SemiBold"/>
                                <TextBlock x:Name="Step1Path" Text="Not selected" FontSize="11" Opacity="0.6"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Select" Click="SetupSelectFolder_Click" Style="{StaticResource AccentButtonStyle}" Padding="12,4"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon x:Name="Step2Icon" Glyph="&#xE73E;" FontSize="16" Foreground="Gray"/>
                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="Core Configuration" FontWeight="SemiBold"/>
                                <CheckBox x:Name="SetupHardRepairCheck" Content="Enable Enhanced Repair Mode" IsChecked="True" FontSize="12"/>
                                <CheckBox x:Name="SetupMultiThreadCheck" Content="Multi-threaded Hashing" IsChecked="True" FontSize="12"/>
                                <CheckBox x:Name="SetupRarMapCheck" Content="Always Create RAR Maps" IsChecked="True" FontSize="12"/>
                                <CheckBox x:Name="SetupSteamCheck" Content="Steam Integration" IsChecked="True" FontSize="12"/>
                                <CheckBox x:Name="SetupDefenderCheck" Content="Antivirus Exclusion" IsChecked="True" FontSize="12"/>

                                <StackPanel Spacing="2" Margin="0,4,0,0">
                                    <TextBlock Text="Hashing Speed Cap (MB/s)" FontSize="11" Opacity="0.8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="SetupSpeedSlider" Minimum="0" Maximum="500" Value="0" StepFrequency="10" TickFrequency="50" TickPlacement="BottomRight"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=SetupSpeedSlider}" VerticalAlignment="Center" Margin="12,0,0,0" Width="30" FontSize="12"/>
                                    </Grid>
                                    <TextBlock Text="(0 = Unlimited. Recommended for HDD: 50)" FontSize="10" Opacity="0.6"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="SetupScanStep" Opacity="0.5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon x:Name="Step3Icon" Glyph="&#xE73E;" FontSize="16" Foreground="Gray"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Scan Locations" FontWeight="SemiBold"/>
                                <TextBlock x:Name="Step3Status" Text="Additional folders to scan for games" FontSize="11" Opacity="0.6"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Manage" Click="SetupScanManage_Click" IsEnabled="False" x:Name="SetupScanBtn" Style="{StaticResource AccentButtonStyle}" Padding="12,4"/>
                        </Grid>

                        <Grid x:Name="SetupLegacyStep" Opacity="0.5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon x:Name="Step4Icon" Glyph="&#xE73E;" FontSize="16" Foreground="Gray"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Maintenance" FontWeight="SemiBold"/>
                                <TextBlock x:Name="Step4Status" Text="Checking for legacy emulator patches..." FontSize="11" Opacity="0.6"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Run Check" Click="SetupLegacyCheck_Click" IsEnabled="False" x:Name="SetupLegacyBtn" Style="{StaticResource AccentButtonStyle}" Padding="12,4"/>
                        </Grid>

                        <Grid x:Name="SetupFinishStep" Opacity="0.5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon x:Name="Step5Icon" Glyph="&#xE73E;" FontSize="16" Foreground="Gray"/>
                            <TextBlock Grid.Column="1" Text="Ready to Launch" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <Button x:Name="FinishSetupBtn" Content="COMPLETE SETUP" Click="FinishSetup_Click" IsEnabled="False" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Height="45" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
        <Grid x:Name="RepairInterceptorOverlay" Visibility="Collapsed" Grid.RowSpan="2" Canvas.ZIndex="1000" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Vertical" Padding="16" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                <TextBlock Text="Anti-Bot Verification Required" FontWeight="Bold" FontSize="16"/>
                <TextBlock Text="Please solve the captcha. If a download button appears, click it to continue." Opacity="0.8" Margin="0,4,0,0"/>
                <Button Content="Cancel" Click="CancelRepairInterceptor_Click" Margin="0,12,0,0"/>
            </StackPanel>
            <WebView2 x:Name="RepairInterceptor" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Grid>

        <Grid x:Name="GlobalWindowDimmer" Background="#CC000000" Visibility="Collapsed" Grid.RowSpan="2" Canvas.ZIndex="950"/>

        <Grid x:Name="GlobalGameInfoPopup" Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
              MaxWidth="800" Margin="24" MaxHeight="750" CornerRadius="12" Visibility="Collapsed" Grid.RowSpan="2" Canvas.ZIndex="1000"
              HorizontalAlignment="Stretch" VerticalAlignment="Center"
              BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderThickness="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Height="120" CornerRadius="12,12,0,0">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF1A1A2E" Offset="0"/>
                        <GradientStop Color="#FF16213E" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <StackPanel Orientation="Horizontal" Margin="24,0" VerticalAlignment="Center" Spacing="20">
                    <Border Width="70" Height="95" CornerRadius="8" Background="#20FFFFFF">
                        <Image x:Name="GlobalPopupHeaderImage" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <TextBlock x:Name="GlobalPopupTitle" Text="Game Title" FontSize="26" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis" MaxWidth="600"/>
                        <TextBlock x:Name="GlobalPopupSubtitle" Text="Version / Tags" FontSize="14" Opacity="0.7" Foreground="White" TextTrimming="CharacterEllipsis" MaxWidth="600"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" Margin="24,20,24,0" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
                <StackPanel Spacing="24">

                    <StackPanel Spacing="8">
                        <TextBlock Text="📖 About This Game" FontWeight="SemiBold" FontSize="16" Opacity="0.8"/>
                        <TextBlock x:Name="GlobalPopupGameInfoText" TextWrapping="Wrap" FontSize="13" Opacity="0.9" LineHeight="20"/>
                    </StackPanel>

                    <Border x:Name="GlobalPopupHowToRunSection" Visibility="Collapsed"
                            Background="#1A0078D4" BorderBrush="#330078D4"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE73E;" FontSize="18" Foreground="#0078D4"/>
                                <TextBlock Text="Installation &amp; Launch Notes" FontWeight="Bold" FontSize="16"/>
                            </StackPanel>
                            <WebView2 x:Name="GlobalPopupHowToRunWebView" Height="180" HorizontalAlignment="Stretch" DefaultBackgroundColor="Transparent"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Spacing="12">
                        <TextBlock Text="📋 Technical Details" FontWeight="SemiBold" FontSize="16" Opacity="0.8"/>
                        <ItemsControl x:Name="GlobalPopupGameInfoList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Key}" FontWeight="SemiBold" Opacity="0.6" FontSize="13"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap" FontSize="13"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <TextBlock Text="⚙️ System Requirements" FontWeight="SemiBold" FontSize="16" Opacity="0.8"/>
                        <ItemsControl x:Name="GlobalPopupRequirementsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Icon}" FontSize="13" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{Binding Key}" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding Value}" TextWrapping="Wrap" FontSize="12" Opacity="0.7"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" Padding="24,16" CornerRadius="0,0,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Click="GlobalPopupOpenBrowser_Click" Background="Transparent" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="World"/>
                        <TextBlock Text="View Web Page"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Content="Close" Click="GlobalPopupClose_Click" Margin="0,0,12,0" Padding="20,8"/>
                <Button x:Name="GlobalPopupDownloadBtn" Grid.Column="2" Click="GlobalPopupDownload_Click" Style="{StaticResource AccentButtonStyle}" Padding="24,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE896;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="16"/>
                        <TextBlock x:Name="GlobalPopupDownloadText" Text="Download Game" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>

        <Border x:Name="GlobalProgressOverlay"
                Visibility="Collapsed"
                Grid.RowSpan="2"
                Background="#AA000000"
                Canvas.ZIndex="999">
            <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalAlignment="Center">
                <ItemsControl x:Name="TasksList" ItemsSource="{x:Bind ActiveOverlayTasks, Mode=OneWay}" Margin="0,40">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:GlobalTask">
                            <Grid Width="420" Padding="28" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="16" BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderThickness="1">
                                <StackPanel Spacing="16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind Title, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold" FontSize="18"/>
                                        <ProgressRing Grid.Column="1" IsActive="True" Width="20" Height="20" Margin="12,0,0,0"/>
                                    </Grid>

                                    <ProgressBar Value="{x:Bind Progress, Mode=OneWay}" IsIndeterminate="{x:Bind IsIndeterminate, Mode=OneWay}" Minimum="0" Maximum="100" Height="8" CornerRadius="4"/>

                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{x:Bind Status, Mode=OneWay}" HorizontalAlignment="Center" Opacity="0.9" TextWrapping="Wrap" TextAlignment="Center" FontSize="13"/>
                                        <TextBlock Text="{x:Bind SubStatus, Mode=OneWay}" HorizontalAlignment="Center" FontSize="11" Opacity="0.5" TextWrapping="Wrap" TextAlignment="Center"/>
                                    </StackPanel>

                                    <Button Content="Run in Background" Click="GlobalOverlayHide_Click" HorizontalAlignment="Stretch" Height="36" Style="{StaticResource AccentButtonStyle}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>